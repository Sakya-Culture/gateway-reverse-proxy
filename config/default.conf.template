upstream nextjs_backend {
    server commentverdict-web-portal:3000;
    keepalive 32;
}

server {
    listen 80;
    server_name commentverdict.com app.commentverdict.com;
    
    return 301 https://$host$request_uri;
}

# HTTPS server
server {
    listen 443 ssl http2;
    server_name commentverdict.com app.commentverdict.com;
    
    # SSL certificates
    #ssl_certificate /etc/nginx/ssl/commentverdict.com.crt;
    #ssl_certificate_key /etc/nginx/ssl/commentverdict.com.key;
    ssl_certificate /etc/nginx/certs/commentverdict.com.fullchain.crt;
    ssl_certificate_key /etc/nginx/certs/commentverdict.com.key;
    
    # SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    
    location / {
        proxy_pass http://nextjs_backend;
        #proxy_http_version 1.1;
        #proxy_set_header Upgrade $http_upgrade;
        #proxy_set_header Connection 'upgrade';
        #proxy_set_header Host $host;
        #proxy_set_header X-Real-IP $remote_addr;
        #proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        #proxy_set_header X-Forwarded-Proto $scheme;
        #proxy_cache_bypass $http_upgrade;
    }
}
