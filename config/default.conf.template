server {
    listen ${NGINX_PORT};
    listen 443 ssl;
    server_name cinekwok.com;
    ssl_certificate /etc/nginx/certs/cinekwok.cer;
    ssl_certificate_key /etc/nginx/certs/cinekwok.key;

    location / {
        proxy_pass http://cinekwok_chn;
        #proxy_set_header HOST ${CINEKWOK_HOST};
    }

    location /eng/ {
    #location ~* ^\/eng\/* {
        proxy_pass http://cinekwok_eng/;
        #proxy_set_header HOST ${CINEKWOK_HOST};
    }

}

server {
    listen 80;
    listen 443 ssl;
    ssl_certificate /etc/nginx/certs/cinekwok.cer;
    ssl_certificate_key /etc/nginx/certs/cinekwok.key;
    server_name farflunginfo.cinekwok.com;

    location / {
        proxy_pass http://drkweb;
        proxy_set_header HOST ${FARFLUNGINFO_HOST};
    }
}

server {
    listen 80;
    server_name ${COMMENTVERDICT_TEST_HOST};
    # Redirect HTTP to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name test.commentverdict.com;

    ssl_certificate /etc/nginx/certs/commentverdict.com.fullchain.crt;
    ssl_certificate_key /etc/nginx/certs/commentverdict.com.key;
    #ssl_trusted_certificate /etc/nginx/certs/commentverdict.com.ca-bundle;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;

    # Optional security headers
